{
  "build": {
    "env": {
      "PYTHON_VERSION": "3.12",
      "PYO3_USE_ABI3_FORWARD_COMPATIBILITY": "1"
    }
  },
  "env": {
    "PYTHON_VERSION": "3.12",
    "PYO3_USE_ABI3_FORWARD_COMPATIBILITY": "1"
  },
  "functions": {
    "api/**/*.py": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
